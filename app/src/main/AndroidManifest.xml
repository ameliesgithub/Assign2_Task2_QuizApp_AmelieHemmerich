            android:exported="false" />
        <activity
            android:name=".admin.EditTournamentActivity"
            android:exported="false" />
        <activity
            android:name=".admin.ViewTournamentsActivity"
            android:exported="false" />
        <activity
            android:name=".admin.CreateTournamentActivity"
            android:exported="false" />
        <activity
            android:name=".player.PlayerDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".admin.AdminDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".auth.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
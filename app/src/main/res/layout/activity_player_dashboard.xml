<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".player.PlayerDashboardActivity"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#9B1446"
        android:padding="24px"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Player Dashboard"
            android:textStyle="bold"
            android:textSize="24dp"
            android:textColor="#FFFFFF"
            android:textAlignment="center"
            />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            />

        <TextView
            android:id="@+id/tvLogoutPlayerDash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textAlignment="viewEnd"
            android:textColor="#FFFFFF"
            android:textSize="16dp"
            />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/llOngoingTournaments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:elevation="8dp"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="@drawable/card_border">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/icon_play"
            app:tint="#9B1446"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ongoing Tournaments"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/llUpcomingTournaments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:elevation="8dp"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="@drawable/card_border">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/icon_forward"
            app:tint="#9B1446"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upcoming Tournaments"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/llPastTournaments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:elevation="8dp"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="@drawable/card_border">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/icon_rewind"
            app:tint="#9B1446"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Past Tournaments"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/llParticipatedTournaments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        android:elevation="8dp"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="@drawable/card_border">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/icon_participation"
            app:tint="#9B1446"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Participated Tournaments"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            />

    </LinearLayout>

</LinearLayout>